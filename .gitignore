# --- Environment / secrets ---
.env
*.local

# --- Experiment payloads (derived; reproduce from config + code) ---
data/raw/**
data/translated/**
data/variants/**
results/**
checkpoints/**          # fine-tuned XLM-R / ESIM weights (derived)
