# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# --- Environment / secrets ---
# (comments must be on their own line — inline comments become part of the pattern)
# .env.* covers every variant (.env.local, .env.gemini, ...); keep the template.
.env
.env.*
!.env.example
*.local
*.key
*.pem
secrets.*

# --- Experiment payloads (derived; reproduce from config + code) ---
data/raw/**
data/translated/**
data/variants/**
results/**
# fine-tuned XLM-R / ESIM weights (derived); SLURM logs; apptainer images
# (comments must be on their own line — inline comments become part of the pattern)
checkpoints/**
cluster/logs/**
*.sif
# keep the directory skeletons and any small committed fixtures
!data/raw/.gitkeep
!data/translated/.gitkeep
!data/variants/.gitkeep
!results/.gitkeep
!**/README.md

# --- Notebooks ---
.ipynb_checkpoints/

# --- LaTeX build artifacts ---
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls
paper/main.pdf
paper/sections/*.aux

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.swp

# --- Claude Code local settings ---
.claude/settings.local.json

# XLM-R fine-tune split (derived; regenerate with training/xlmr_csqa/make_split.py)
training/xlmr_csqa/splits/**
