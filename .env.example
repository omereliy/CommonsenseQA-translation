# Copy to `.env` and fill in only the keys for backends you actually use.
# `.env` is git-ignored AND deny-listed in .claude/settings.json — never commit it.

# API-based models (evaluation and/or LLM translation)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Hugging Face (gated/private models, higher rate limits)
HF_TOKEN=

# Translation — Google Cloud Translation v2 REST (the resolved backend; an API key)
GOOGLE_API_KEY=

# Optional alternative MT providers / service-account auth
# DEEPL_API_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=

# Optional: path to glove.6B.300d.txt for the ESIM anchor (else random-init)
# GLOVE_PATH=
